   <span class="n">importance</span> <span class="o">=</span> <span class="n">ENSTREE</span><span class="o">.</span><span class="n">feature_importances_</span>
   <span class="n">index</span> <span class="o">=</span> <span class="n">np</span><span class="o">.</span><span class="n">argsort</span><span class="p">(</span><span class="n">importance</span><span class="p">)</span>
   <span class="n">theList</span> <span class="o">=</span> <span class="p">[]</span>
   <span class="k">for</span> <span class="n">i</span> <span class="ow">in</span> <span class="n">index</span> <span class="p">:</span>
       <span class="n">imp_val</span> <span class="o">=</span> <span class="n">importance</span><span class="p">[</span><span class="n">i</span><span class="p">]</span>
       <span class="k">if</span> <span class="n">imp_val</span> <span class="o">&gt;</span> <span class="n">np</span><span class="o">.</span><span class="n">average</span><span class="p">(</span><span class="n">ENSTREE</span><span class="o">.</span><span class="n">feature_importances_</span><span class="p">)</span> <span class="p">:</span>
